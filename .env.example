# AudD Music Recognition — https://audd.io
# Sign up for a free token at https://dashboard.audd.io
# First 300 requests are free
AUDD_API_TOKEN=

# YouTube Data API v3 — https://console.cloud.google.com
YOUTUBE_API_KEY=

# Notion integration
NOTION_API_KEY=
NOTION_ACTIVITY_PAGE_ID=

# Descript API (for "Create Beautiful Video")
DESCRIPT_API_TOKEN=
# Optional override. Defaults to https://descriptapi.com/v1
DESCRIPT_API_BASE_URL=

# AWS S3 (for presigned upload + source media URL)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
